# 로컬 개발: Firebase 에뮬레이터 사용 (true)
VITE_USE_EMULATOR=true

# 실서버 배포 시: VITE_USE_EMULATOR=false 로 바꾸고 아래 값을 실제 프로젝트 값으로 채우세요.
# (Firebase 콘솔 > 프로젝트 설정 > 내 앱 > SDK 설정 및 구성)
VITE_FB_API_KEY=demo-api-key
VITE_FB_AUTH_DOMAIN=worldcup-gonom-event.firebaseapp.com
VITE_FB_PROJECT_ID=worldcup-gonom-event
VITE_FB_STORAGE_BUCKET=worldcup-gonom-event.appspot.com
VITE_FB_MESSAGING_SENDER_ID=000000000000
VITE_FB_APP_ID=1:000000000000:web:0000000000000000000000
