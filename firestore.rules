rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 공개 읽기 전용: 이벤트 설정 / 등급 / 카드 도감 정보
    // (뽑기 화면·도감 표시에 필요. 쓰기는 절대 클라이언트에서 불가)
    match /config/{doc} {
      allow read: if true;
      allow write: if false;
    }
    match /grades/{doc} {
      allow read: if true;
      allow write: if false;
    }
    match /cards/{doc} {
      allow read: if true;
      allow write: if false;
    }
    // 응원 팀 목록 (응원전 팀 선택에 필요). 쓰기는 Functions/Admin 통해서만.
    match /teams/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // 유저/뽑기 기록은 클라이언트가 직접 읽거나 쓸 수 없음.
    // 모든 접근은 Cloud Functions(Admin SDK)를 통해서만 이루어짐.
    match /users/{doc} {
      allow read, write: if false;
    }
    match /draws/{doc} {
      allow read, write: if false;
    }

    // 그 외 모든 경로 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
